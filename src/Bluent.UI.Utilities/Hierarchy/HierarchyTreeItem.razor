@using Bluent.UI.Components
@using Bluent.UI.Utilities
@namespace Bluent.UI.Utilities
<TreeItem Expandable="ShouldExpand"
          Expanded="_expanded"
          ExpandedChanged="OnExpandChanged"
          Icon="@Icon"
          ExpandedIcon="@ExpandedIcon"
          OnClick="HandleClick">
    <ItemTemplate>
        <div class="p-2 rounded-5 d-flex align-items-center text-truncate @(IsSelected ? "bg-3" : "")">
            <div class="flex-fill text-truncate">@Item.Name</div>
            @if (Options != null)
            {
                @Options.Invoke(Item)
            }
        </div>
    </ItemTemplate>
    <ChildContent>
        @if (_items != null)
        {
            foreach (var hierarchyItem in _items.Where(x => !TreeBrowser.RootOnly || x is HierarchyRootItem))
            {
                <CascadingValue Value="this" IsFixed>
                    <HierarchyTreeItem Item="hierarchyItem"
                                       Options="Options"/>
                </CascadingValue>
            }
        }
    </ChildContent>
</TreeItem>